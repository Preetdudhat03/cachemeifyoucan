{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:frontend": "next dev --webpack",
    "dev:backend": "uvicorn backend.main:app --app-dir .. --reload --port 8000",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build": "next build",
    "start": "concurrently \"next start\" \"uvicorn backend.main:app --app-dir .. --host 0.0.0.0 --port 8000\"",
    "lint": "eslint"
  },
  "dependencies": {
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "plotly.js": "^3.4.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-plotly.js": "^2.6.0",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^82.2.2",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "optionalDependencies": {
    "lightningcss-linux-x64-gnu": "^1.28.1"
  }
}